{
	"version": 1,
	"base_image": "codeocean/mosuite:latest",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"rcran": {
			"packages": [
				{
					"name": "argparse",
					"version": "2.3.1"
				},
				{
					"name": "remotes",
					"version": "2.5.0"
				}
			],
			"use_rcache": true
		}
	}
}
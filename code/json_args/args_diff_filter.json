{
  "moo_input_rds": "../results/RDS/moo.cleaned.filtered.normalized.diff.rds",
  "moo_output_rds": "../results/RDS/moo.cleaned.filtered.normalized.diff.filtered.rds",
  "significance_column": "adjpval",
  "significance_cutoff": $SIG_THRESHOLD,
  "change_column": "logFC",
  "change_cutoff": $FC_CUTOFF,
  "filtering_mode": "any",
  "include_estimates": ["FC", "logFC", "tstat", "pval", "adjpval"],
  "round_estimates": true,
  "rounding_decimal_for_percent_cells": 0,
  "contrast_filter": "$CONTRAST_FILTER",
  "contrasts": ["$CONTRAST_NAMES_FILTER"],
  "groups": ["$GROUPS_NAMES_FILTER"],
  "groups_filter": "$GROUPS_FILTER",
  "label_font_size": $DIFF_LABEL_FONT_SIZE,
  "label_distance": $DIFF_LABEL_DIST,
  "y_axis_expansion": $DIFF_Y_EXPAN,
  "fill_colors": [$DIFF_FILL_COLOURS],
  "pie_chart_in_3d": true,
  "bar_width": $DIFF_BAR_WIDTH,
  "draw_bar_border": "$DIFF_BAR_BORDER",
  "plot_type": "$DIFF_PLOT_TYPE",
  "plot_titles_fontsize": 12
}
